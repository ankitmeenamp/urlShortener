<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/7.4.47/css/materialdesignicons.min.css">
    
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/material-design-iconic-font/2.2.0/css/material-design-iconic-font.min.css">

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body{
            background:#f4f6f9;
            display:flex;
            justify-content:center;
            align-items:center;
            min-height:100vh;
        }

        .profile-container{
            width:700px;
        }

        .page-title{
            text-align:center;
            margin-bottom:20px;
            color:#333;
        }

        .status-badge{
            display:inline-flex;
            align-items:center;
            gap:8px;
            padding:10px 15px;
            border-radius:20px;
            margin-bottom:20px;
            font-size:14px;
        }

        .success{
            background:#d4edda;
            color:#155724;
        }

        .warning{
            background:#fff3cd;
            color:#856404;
        }

        .profile-card{
            background:#fff;
            border-radius:12px;
            padding:25px;
            box-shadow:0 2px 10px rgba(0,0,0,.1);
        }

        .profile-header{
            display:flex;
            align-items:center;
            gap:20px;
            margin-bottom:25px;
        }

        .avatar-placeholder{
            width:80px;
            height:80px;
            border-radius:50%;
            background:#4f46e5;
            color:white;
            display:flex;
            justify-content:center;
            align-items:center;
            font-size:32px;
            font-weight:bold;
        }

        .profile-name{
            font-size:24px;
            color:#333;
        }

        .profile-email{
            color:#666;
            margin-top:5px;
        }

        .member-since{
            color:#888;
            margin-top:8px;
        }

        .profile-stats{
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:15px;
            margin-top:20px;
        }

        .stat-item{
            background:#f8fafc;
            padding:20px;
            text-align:center;
            border-radius:10px;
        }

        .stat-value{
            display:block;
            font-size:24px;
            font-weight:bold;
            color:#4f46e5;
        }

        .stat-label{
            color:#666;
            font-size:14px;
        }
        .profile-card{
    background:#fff;
    border-radius:6px;
    overflow:hidden;
    box-shadow:0 2px 10px rgba(0,0,0,.15);
}

.profile-header{
    background:linear-gradient(to right,#66aaf7,#4b90e2);
    color:white;
    padding:18px 20px;
    display:flex;
    align-items:center;
    gap:15px;
    margin:0;
}

.avatar-placeholder{
    width:50px;
    height:50px;
    border-radius:50%;
    border:2px solid rgba(255,255,255,.5);
    background:transparent;
    font-size:20px;
    font-weight:500;
}

.profile-name{
    color:white;
    font-size:15px;
    text-transform:uppercase;
    margin-bottom:5px;
}

.profile-email,
.member-since{
    color:rgba(255,255,255,.85);
    font-size:11px;
    margin:2px 0;
}

.profile-stats{
    display:flex;
    justify-content:space-around;
    padding:15px 0;
    background:white;
}

.stat-item{
    background:none;
    padding:0;
}

.stat-value{
    font-size:16px;
    color:#222;
    font-weight:500;
}

.stat-label{
    display:block;
    margin-top:5px;
    color:#999;
    font-size:10px;
    text-transform:uppercase;
}

.profile-actions{
    margin-top:15px;
    display:flex;
    justify-content:center;
    gap:8px;
}

.btn{
    background:#6eaef5;
    color:#fff;
    text-decoration:none;
    padding:8px 18px;
    border-radius:2px;
    font-size:12px;
    min-width:120px;
    text-align:center;
}

.btn:hover{
    background:#4b90e2;
}
.profile-verification {
    padding: 20px 28px;
    background: #fefefe;
    border-bottom: 1px solid #eef2f6;
}

.verification-status {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.95rem;
    background: #f9fafc;
    padding: 12px 20px;
    border-radius: 60px;
    margin: 0;
}

.verification-label {
    font-weight: 600;
    color: #1e293b;
}

.verification-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 40px;
    font-size: 0.8rem;
    font-weight: 500;
}

.verified {
    background: #dcfce7;
    color: #15803d;
    border: 1px solid #bbf7d0;
}

.not-verified {
    background: #ffe8e0;
    color: #c2410c;
    border: 1px solid #ffd8c2;
}

.verify-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #2563eb;
    color: white;
    padding: 6px 16px;
    border-radius: 40px;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 500;
}

.verify-link:hover {
    background: #1d4ed8;
}
    </style>
</head>
<body>
<%- include('../partials/header.ejs') %>
<div class="profile-container">

    <h1 class="page-title">Your Profile</h1>

    <% if(user) { %>
        <div class="status-badge success">
            <i class="mdi mdi-check-circle"></i>
            <span>You are logged in</span>
        </div>
    <% } else { %>
        <div class="status-badge warning">
            <i class="mdi mdi-alert-circle"></i>
            <span>You are not logged in</span>
        </div>
    <% } %>

    <div class="profile-card">

        <div class="profile-header">

            <div class="profile-avatar">
                <div class="avatar-placeholder">
                    <span><%= user.name.charAt(0).toUpperCase() %></span>
                </div>
            </div>

            <div class="profile-info">
                <h2 class="profile-name">
                    <%= user.name %>
                </h2>

                <p class="profile-email">
                    <i class="mdi mdi-email"></i>
                    <%= user.email %>
                </p>

                <p class="member-since">
                    <i class="mdi mdi-calendar"></i>
                    Member since
                    <%= new Date(user.createAt).toLocaleDateString() %>
                </p>
            </div>

        </div>

        <div class="profile-stats">

            <div class="stat-item">
                <span class="stat-value">
                    <%= user.links ? user.links.length : 0 %>
                </span>
                <span class="stat-label">
                    Links Created
                </span>
            </div>

            <div class="stat-item">
                <span class="stat-value">
                    <%= user.totalClicks || 0 %>
                </span>
                <span class="stat-label">
                    Total Clicks
                </span>
            </div>

            <div class="stat-item">
                <span class="stat-value">
                    <%= user.lastActive ? new Date(user.lastActive).toLocaleDateString() : "Today" %>
                </span>
                <span class="stat-label">
                    Last Active
                </span>
            </div>
        </div>


       <div class="profile-verification">
    <p class="verification-status">
        <span class="verification-label">
            Email Verification:
        </span>

        <% if (user.isEmailValid) { %>
            <span class="verification-badge verified">
                <i class="zmdi zmdi-check-circle"></i>
                Verified
            </span>
        <% } else { %>
            <span class="verification-badge not-verified">
                <i class="zmdi zmdi-alert-circle"></i>
                Not Verified
            </span>
            <a href="/verify-email" class="verify-link">
                <i class="zmdi zmdi-mail-send"></i>
                Verify Now
            </a>
        <% } %>
    </p>
</div>

    </div>

    <div class="profile-actions">
    <a href="/edit-profile" class="btn">
        <i class="mdi mdi-pencil"></i> Edit Profile
    </a>

    <a href="/change-password" class="btn">
        <i class="mdi mdi-key"></i> Change Password
    </a>

    <a href="/logout" class="btn">
        <i class="mdi mdi-logout"></i> Logout
    </a>
</div>

</div>

</body>
</html>